{
	"enableAllProjectMcpServers": true,
	"hooks": {
		"PostToolUse": [
			{
				"hooks": [
					{
						"command": "pnpm -w validate:fix",
						"type": "command"
					}
				],
				"matcher": "Write|Edit"
			}
		]
	},
	"permissions": {
		"allow": [
			"mcp__serena",
			"Bash(pnpm -w dev:*)",
			"Bash(pnpm -w build:*)",
			"Bash(pnpm -w start:*)",
			"Bash(pnpm -w db:generate:*)",
			"Bash(pnpm -w db:migrate:*)",
			"Bash(pnpm -w db:push:*)",
			"Bash(pnpm -w db:reset:*)",
			"Bash(pnpm -w db:seed:*)",
			"Bash(pnpm -w test:browser:*)",
			"Bash(pnpm -w test:server:*)",
			"Bash(pnpm -w test:e2e:*)",
			"Bash(pnpm -w validate:check)",
			"Bash(pnpm -w validate:fix)",
			"Bash(pnpm --filter:*)",
			"Bash(git push:*)",
			"Bash(git commit:*)",
			"Bash(git add:*)",
			"Bash(git --no-pager show:*)",
			"Bash(git --no-pager diff:*)",
			"Bash(git --no-pager log:*)",
			"Bash(git branch:*)",
			"Bash(git remote:*)",
			"Bash(git merge-base:*)",
			"Bash(gh:*)",
			"Bash(curl:*)",
			"Read(.env.sample)",
			"Write(.env.sample)",
			"WebFetch(domain:context7.com)",
			"WebFetch(domain:api.github.com)"
		],
		"ask": [],
		"deny": ["Read(.env*)", "Write(.env*)"]
	},
	"sandbox": {
		"autoAllowBashIfSandboxed": true,
		"enabled": true,
		"excludedCommands": ["git:*", "pnpm:*", "docker:*", "gh:*"]
	}
}
