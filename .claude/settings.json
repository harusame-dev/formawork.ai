{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"enableAllProjectMcpServers": true,
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"command": "echo '## 参照可能な agent-docs ドキュメント一覧' && ls agent-docs/ | sed 's/^/- /'",
						"type": "command"
					}
				]
			}
		]
	},
	"language": "japanese",
	"permissions": {
		"allow": [
			"Skill(*)",
			"Bash(gh *)",
			"Bash(pnpm -w test:browser*)",
			"Bash(pnpm -w test:e2e*)",
			"Bash(playwright-cli *)"
		],
		"ask": [],
		"deny": [
			"Bash(gh issue delete *)",
			"Bash(gh issue lock *)",
			"Bash(gh issue unlock *)",
			"Bash(gh pr close *)",
			"Bash(gh pr merge *)",
			"Bash(gh pr lock *)",
			"Bash(gh pr unlock *)",
			"Bash(gh release *)",
			"Bash(gh repo *)",
			"Bash(gh secret *)",
			"Bash(gh variable *)",
			"Bash(gh workflow *)",
			"Bash(gh auth *)",
			"Bash(gh ssh-key *)",
			"Bash(gh gpg-key *)",
			"Bash(gh label delete *)",
			"Bash(gh milestone delete *)",
			"Bash(gh api *)",
			"Bash(gh gist *)",
			"Bash(gh codespace *)",
			"Bash(gh extension *)"
		]
	},
	"sandbox": {
		"autoAllowBashIfSandboxed": true,
		"enabled": true,
		"excludedCommands": [
			"gh:*",
			"pnpm -w test:browser:*",
			"pnpm -w test:e2e:*",
			"playwright-cli:*"
		],
		"filesystem": {
			"allowWrite": ["//tmp/pnpm/store"]
		},
		"network": {
			"allowedDomains": [
				"api.github.com",
				"registry.npmjs.org",
				"github.com",
				"docs.anthropic.com"
			],
			"allowLocalBinding": true
		}
	}
}
