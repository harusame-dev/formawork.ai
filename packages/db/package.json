{
	"dependencies": {
		"drizzle-orm": "catalog:",
		"postgres": "catalog:",
		"valibot": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@workspace/tsconfig": "workspace:",
		"drizzle-kit": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	},
	"exports": {
		"./client": "./src/client.ts",
		"./pgschema": "./src/pgschema.ts",
		"./schema": "./src/schema/index.ts",
		"./schema/chat": "./src/schema/chat.ts",
		"./schema/chat-message": "./src/schema/chat-message.ts",
		"./schema/chat-todo": "./src/schema/chat-todo.ts",
		"./schema/consultation": "./src/schema/consultation.ts",
		"./schema/organization": "./src/schema/organization.ts",
		"./schema/organization-category": "./src/schema/organization-category.ts",
		"./schema/user": "./src/schema/user.ts"
	},
	"name": "@workspace/db",
	"private": true,
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"db:migrate": "pnpm db:pgschema:create && tsx --env-file-if-exists=.env src/migrate.ts",
		"db:pgschema:create": "tsx --env-file-if-exists=.env src/create-pg-schema.ts",
		"db:pgschema:drop": "tsx --env-file-if-exists=.env src/drop-pg-schema.ts",
		"db:reset": "pnpm db:pgschema:drop && pnpm db:migrate && pnpm db:seed",
		"db:seed": "tsx --env-file-if-exists=.env src/seed.ts",
		"db:studio": "drizzle-kit studio",
		"type:check": "tsc --noEmit"
	},
	"type": "module",
	"version": "0.0.0"
}
